<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
    <link href="/css/polaris.css?v=3" rel="stylesheet" type="text/css"/>
    <link href="/assets/polaris.svg" rel="icon"/>
    <title><%= t('config_page.global.page_title') %></title>
    <meta content="Polaris" property="og:title"/>
    <meta content="An open-source XP bot" property="og:description"/>
    <meta content="website" property="og:type"/>
    <meta content="#00ff80" name="theme-color"/>
    <meta content="summary" name="twitter:card"/>
    <meta content="noindex" name="robots"/>
</head>
<body>
    <h2 class="middleflex" id="loading" style="margin-top: 75px; width: 100%; position: absolute;"><%= t('config_page.global.loading') %></h2>
    <div id="everything" style="display: none;">
        <div id="sidebar">
            <div tabindex="0" category="server" class="category" title="<%= t('config_page.sidebar.home_desc') %>">
                <img class="serverIcon" style="border-radius: 420px"> <p><%= t('config_page.sidebar.home') %></p>
            </div>
            <div tabindex="0" category="xp" class="category" title="<%= t('config_page.sidebar.xp_desc') %>">
                <i data-lucide="sparkles"></i>
                <p><%= t('config_page.sidebar.xp') %></p>
            </div>
            <div tabindex="0" category="rewardroles" class="category" title="<%= t('config_page.sidebar.rewards_desc') %>">
                <i data-lucide="gift"></i>
                <p><%= t('config_page.sidebar.rewards') %></p>
            </div>
            <div tabindex="0" category="levelup" class="category" title="<%= t('config_page.sidebar.levelup_desc') %>">
                <i data-lucide="message-square-plus"></i>
                <p><%= t('config_page.sidebar.levelup') %></p>
            </div>
            <div tabindex="0" category="multipliers" class="category" title="<%= t('config_page.sidebar.multipliers_desc') %>">
                <i data-lucide="zap"></i>
                <p><%= t('config_page.sidebar.multipliers') %></p>
            </div>
            <div tabindex="0" category="rankcard" class="category" title="<%= t('config_page.sidebar.rankcard_desc') %>">
                <i data-lucide="id-card"></i>
                <p><%= t('config_page.sidebar.rankcard') %></p>
            </div>
            <div tabindex="0" category="leaderboard" class="category" title="<%= t('config_page.sidebar.leaderboard_desc') %>">
                <i data-lucide="bar-chart-2"></i>
                <p><%= t('config_page.sidebar.leaderboard') %></p>
            </div>
            <div tabindex="0" category="data" class="category" title="<%= t('config_page.sidebar.data_desc') %>">
                <i data-lucide="database"></i>
                <p><%= t('config_page.sidebar.data') %></p>
            </div>
            <div tabindex="0" category="advanced" class="category" title="<%= t('config_page.sidebar.advanced_desc') %>">
                <i data-lucide="settings"></i>
                <p><%= t('config_page.sidebar.advanced') %></p>
            </div>
        </div>
        
        <div id="unsavedWarning">
            <div class="unsavedBox">
                <p><%= t('config_page.global.unsaved_text') %></p>
                <button id="saveChanges" style="background-color: var(--emojigreen)"><%= t('config_page.global.btn_save') %></button>
            </div>
        </div>

        <div class="configboxes" id="serverInfo" style="display: none" tab="server">
            <div class="settingBox box fulllength" style="padding: 15px 20px; position: relative">
                <div class="centerflex">
                    <img class="serverIcon" style="border-radius: 420px; height: 75px"/>
                    <div style="margin-left: 18px; overflow: hidden;">
                        <h1 class="serverName" style="text-overflow: ellipsis; overflow: hidden; white-space: nowrap; margin-bottom: 0px"></h1>
                        <p class="serverMembers" style="margin-top: 0px"></p>
                    </div>
                </div>
                <div class="middleflex" style="position: absolute; top: 0px; right: 30px; height: 100%">
                    <a href="/servers" tabindex="-1">
                        <button style="font-size: 24px; height: 50px; width: 200px; margin-right: 25px; background-color: var(--emojiblue)"><%= t('dashboard.ChangeServer') %></button>
                    </a>
                    <a class="leaderboardLink" id="mainlbbutton" tabindex="-1" target="_blank">
                        <button style="font-size: 24px; height: 50px; width: 200px; background-color: var(--emojipurple)"><%= t('dashboard.Leaderboard') %></button>
                    </a>
                </div>
            </div>
            <div class="settingBox box categoryBox canfocus" tabindex="0">
                <div class="centerflex">
                    <div cat="icon" class="icon-container"></div> 
                    <div style="overflow: hidden">
                        <h2 cat="name"></h2>
                        <p cat="info" class="details" style="height: 56px"></p>
                        <p cat="extra" style="white-space: nowrap"></p>
                    </div>
                </div>
            </div>
        </div>

        <div class="configboxes" style="display: none" tab="xp">
            <div class="settingBox box fulllength">
                <h1><%= t('dashboard.XPGain') %></h1>
                <p><%= t('dashboard.WheneveramembersendsamessagetheygainarandomamountofXPexperiencepointsandtriggerashortcooldownWhenthecooldownfinishestheycangainmoreXPCongratulationsYoujustlearnedhowXPbotswork') %></p>
                <h2><%= t('dashboard.EnableXP') %></h2>
                <p class="details"><%= t('dashboard.WhenenabledmemberswillbeabletogainXPThisisthewholepointofthebot') %></p>
                <label class="slider" style="margin-top: 5px">
                    <input db="enabled" id="enableLevelUp" savename="db" type="checkbox"/>
                    <span class="sliderspan"></span>
                </label>
            </div>
            <div class="settingBox box fulllength">
                <h1><%= t('dashboard.BasicSettings') %></h1>
                <p><%= t('dashboard.CustomizetheamountofXPearnedaswellashowoftenitcanbegainedEasyenough') %></p>
                <div class="simpleflex">
                    <div class="sideoption">
                        <h2><%= t('dashboard.XPpermessage') %></h2>
                        <p class="details"><%= t('dashboard.Amountisrandomlypickedbetweentheminandmaxvalue') %></p>
                        <div class="field">
                            <div class="centerflex spacedflex">
                                <p><%= t('dashboard.Between') %></p>
                                <input db="gain.min" default="50" id="num_min" max="5000" min="0" savename="db" style="width: 75px" type="number" updatecurve="true"/>
                                <p><%= t('dashboard.and') %></p>
                                <input db="gain.max" default="50" id="num_max" max="5000" min="0" savename="db" style="width: 75px" type="number" updatecurve="true"/>
                            </div>
                        </div>
                    </div>
                    <div class="sideoptions">
                        <h2><%= t('dashboard.Cooldown') %></h2>
                        <p class="details"><%= t('dashboard.MembersmustwaitthismanysecondsbeforetheycangainXPagain') %></p>
                        <div class="field">
                            <div class="centerflex spacedflex">
                                <input db="gain.time" decimals="4" default="60" id="num_time" max="31536000" min="0" savename="db" style="width: 100px" type="number" updatecurve="true"/>
                                <p><%= t('dashboard.seconds') %></p>
                                <p id="cooldownunit" style="opacity: 70%; display: none"></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="settingBox box fulllength">
                <h1><%= t('dashboard.LevelScaling') %></h1>
                <p><%= t('dashboard.BygainingenoughXPmemberscanlevelupandearnspecialrolesorbraggingrightsTheamountofXPrequiredscaleswitheachlevelearlylevelsonlyneedacouplethousandpointsbutlaterlevelsneedmillions') %></p>
                <p><%= t('dashboard.YoucanadjustthelevelscalingtochangehowmanymorepointsarerequiredwitheachlevelAsmallercurvemakesiteasiertolevelupandalargercurvemakesitmuchmoredifficult') %></p>
                <div class="simpleflex">
                    <div class="sideoption">
                        <h2 id="curveStuff"><%= t('dashboard.Curveformula') %></h2>
                        <p class="details"><%= t('dashboard.CubicfunctionthatdetermineshowmuchXPisneededforeachlevel') %></p>
                        <div class="field">
                            <div class="centerflex curvefield">
                                <input db="curve.3" decimals="10" default="0" id="num_curve3" max="100" min="0" savename="db" style="width: 65px" type="number" updatecurve="true"/>
                                <p>x<sup>3</sup>     + </p>
                                <input db="curve.2" decimals="10" default="0" id="num_curve2" max="10000" min="0" savename="db" style="width: 65px" type="number" updatecurve="true"/>
                                <p>x<sup>2</sup>     + </p>
                                <input db="curve.1" decimals="10" default="0" id="num_curve1" max="100000" min="0" savename="db" style="width: 65px" type="number" updatecurve="true"/>
                                <p>x</p>
                            </div>
                        </div>
                        <p><%= t('dashboard.Difficultyrating') %><b id="scaleDifficulty" style="color: aqua"></b></p>
                    </div>
                    <div class="sideoption">
                        <h2><%= t('dashboard.Rounding') %></h2>
                        <p class="details"><%= t('dashboard.RoundstherequiredXPtoanicernumbereg791XP800XP') %></p>
                        <div class="centerflex spacedflex">
                            <p><%= t('dashboard.Roundtonearest') %></p>
                            <input db="rounding" default="1" id="num_round" max="1000" min="1" savename="db" style="width: 80px" type="number" updatecurve="true"/>
                        </div>
                    </div>
                </div>
                <div style="display: flex; flex-direction: column; gap: 30px; width: 100%;">
                    <div>
                        <h2 style="margin-bottom: 12px"><%= t('dashboard.Preview') %></h2>
                        <div class="simpleflex flexTable" id="curvePreview"></div>
                        <button id="showMoreCurveInfo" style="margin-top: 16px; width: 140px"><%= t('dashboard.Moreinfo') %></button>
                    </div>
                    <div>
                    <div class="desmos" id="xpGraph"></div>
                        <p class="details" id="desmosJumpscare" style="font-size: 10px; opacity: 25%"><%= t('dashboard.desmosjumpscare') %></p>
                    </div>
                </div>
                <div id="fullPreviewSection" style="display: none">
                    <h2 style="margin-bottom: 12px"><%= t('dashboard.FullTable') %></h2>
                    <div class="simpleflex flexTable" id="fullCurvePreview"></div>
                    <button onclick="$('#fullPreviewSection').hide()" style="margin-top: 16px; width: 140px; background-color: var(--emojipurple)"><%= t('dashboard.Hide') %></button>
                </div>
            </div>
            <div class="settingBox box fulllength">
                <h1><%= t('dashboard.Presets') %></h1>
                <p><%= t('dashboard.BalancingishardHeressomepresetstopickfrom') %></p>
                <div class="simpleflex">
                    <div style="width: 750px">
                        <h2><%= t('dashboard.Viewpreset') %></h2>
                        <p class="details"><%= t('dashboard.Nosettingswillbechangeduntilyouclickapply') %></p>
                        <select id="curvePresets"></select>
                        <p id="presetDesc" style="margin-bottom: 8px; font-style: italic;"><%= t('dashboard.Curvedescription') %></p>
                        <div class="curveInfo">
                            <p>- <b><%= t('dashboard.Curve') %></b> <span id="presetCurve"></span></p>
                            <p>- <b><%= t('dashboard.Difficulty') %></b> <span id="presetDifficulty"></span></p>
                            <p>- <b><%= t('dashboard.Rounding') %></b> <span id="presetRound"></span></p>
                            <p>- <b><%= t('dashboard.XPpermessage') %></b> <span id="presetXP"></span></p>
                        </div>
                        <button id="applyPreset" style="margin-top: 12px;"><%= t('dashboard.ApplyPreset') %></button>
                    </div>
                </div>
            </div>
        </div>

        <div class="configboxes" style="display: none" tab="rewardroles">
            <div class="settingBox box fulllength">
                <h1><%= t('dashboard.RewardRoles') %></h1>
                <p style="margin-bottom: 3px"><%= t('dashboard.AutomaticallygiverolestomemberswhentheyreachcertainlevelsForfree') %></p>
                <p class="details"><%= t('dashboard.ImagineifItriedtocapitalizeoffacoupleextralinesofcodehahathatwouldbeabsolutelycrazy') %></p>
                <h2><%= t('dashboard.Addrole') %></h2>
                <div class="centerflex spacedflex" style="margin-top:10px">
                    <p><%= t('dashboard.Reward') %></p>
                    <select id="rewardRoleSelect"></select>
                    <p><%= t('dashboard.atlevel') %></p>
                    <input id="rewardLevel" max="1000" min="1" style="width: 90px" type="number"/>
                </div>
                <div class="centerflex spacedflex">
                    <p><%= t('dashboard.Removethisrolewhenahigherroleisobtained') %></p>
                    <label class="slider" style="margin-top: 5px">
                        <input checked="" id="rewardKeep" type="checkbox"/>
                        <span class="sliderspan"></span>
                    </label>
                </div>
                <div class="centerflex spacedflex excludeMode">
                    <p><%= t('dashboard.AdvancedExcludethisrolewhensyncingroles') %></p>
                    <label class="slider" style="margin-top: 5px">
                        <input id="rewardExclude" type="checkbox"/>
                        <span class="sliderspan"></span>
                    </label>
                </div>
                <button id="addRewardRole" style="margin-top: 10px"><%= t('dashboard.Add') %></button>
                <h2 style="margin-top: 50px; margin-bottom: 15px"><%= t('dashboard.Currentrewards') %><span id="rewardCount">0</span>)</h2>
                <div class="simpleflex flexTable" id="rewards"></div>
            </div>
            <div class="settingBox box fulllength">
                <h1><%= t('dashboard.RewardSyncing') %></h1>
                <p><%= t('dashboard.BydefaultthebotwillautomaticallysynclevelrolesbyaddingmissingonesandremovingincorrectonesFeelfreetotweakthisbehaviouralittle') %></p>
                <div class="simpleflex">
                    <div class="sideoption">
                        <h2><%= t('dashboard.Automaticsyncing') %></h2>
                        <p class="details"><%= t('dashboard.Choosewhenthebotshouldautomaticallysynclevelroles') %></p>
                        <select db="rewardSyncing.sync" savename="db">
                            <option value="level"><%= t('dashboard.Onlevelup') %></option>
                            <option value="xp"><%= t('dashboard.OnXPgainslower') %></option>
                            <option value="never"><%= t('dashboard.Never') %></option>
                        </select>
                    </div>
                    <div class="sideoptions">
                        <h2><%= t('dashboard.Manualsyncing') %></h2>
                        <p class="details"><%= t('dashboard.Ifmembersshouldbeabletomanuallysynctheirroleswhenevertheywant') %></p>
                        <label class="slider" style="margin-top: 5px">
                            <input db="rewardSyncing.noManual" invert="true" savename="db" tabindex="0" type="checkbox"/>
                            <span class="sliderspan"></span>
                        </label>
                    </div>
                </div>
                <div class="simpleflex" style="margin-top: 40px">
                    <div class="sideoption">
                        <h2><%= t('dashboard.Showsyncwarning') %></h2>
                        <p class="details"><%= t('dashboard.Displaysawarningmessageinrankifamembersrolesarentsyncedproperly') %></p>
                        <label class="slider" style="margin-top: 5px">
                            <input db="rewardSyncing.noWarning" invert="true" savename="db" tabindex="0" type="checkbox"/>
                            <span class="sliderspan"></span>
                        </label>
                    </div>
                    <div class="sideoptions">
                        <h2><%= t('dashboard.AdvancedExcluderoles') %></h2>
                        <p class="details"><%= t('dashboard.Preventcertainrolesfrombeingreaddedorremovedwhensyncing') %></p>
                        <label class="slider" style="margin-top: 5px">
                            <input id="excludeRewardToggle" tabindex="0" type="checkbox"/>
                            <span class="sliderspan"></span>
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <div class="configboxes" style="display: none" tab="levelup">
            <div class="settingBox box fulllength">
                <h1><%= t('dashboard.Levelupmessage') %></h1>
                <p><%= t('dashboard.SendanautomaticmessageinthechatwhenamemberlevelsupHowfun') %></p>
                <h2><%= t('dashboard.Enablemessage') %></h2>
                <p class="details"><%= t('dashboard.WhenenabledamessageorDMwillbesentwheneveranyonelevelsup') %></p>
                <label class="slider" style="margin-top: 5px">
                    <input db="levelUp.enabled" onchange="$('.ifmessageenabled').toggle($(this).prop('checked'))" savename="db" type="checkbox"/>
                    <span class="sliderspan"></span>
                </label>
            </div>
            <div class="settingBreak"></div>
            <div class="settingBox box fulllength ifmessageenabled">
                <div id="regularMessage">
                    <h1><%= t('dashboard.Message') %></h1>
                    <p><%= t('dashboard.Themessagetosenduponlevellingup') %></p>
                    <textarea class="lvlTextbox" id="lvlUpMessage" placeholder="(no message)" savename="levelUp.message" style="width: 800px"></textarea>
                </div>
                <div id="embedMessage">
                    <h1><%= t('dashboard.Embed') %></h1>
                    <p><%= t('dashboard.Theembeddedmessagetosenduponlevellingup') %></p>
                    <p><b><%= t('dashboard.Step1') %></b> <a href="https://discohook.org/?" target="_blank"><%= t('dashboard.Generateanembedhere') %></a></p>
                    <p><b><%= t('dashboard.Step2') %></b><%= t('dashboard.OpentheJSONdatabypressingJSONDataEditoratthebottomofthesite') %></p>
                    <p><b><%= t('dashboard.Step3') %></b><%= t('dashboard.Copythetextandpasteitintheboxbelow') %></p>
                    <p class="details" style="margin-bottom: 15px"><%= t('dashboard.AllvariablesegUSERNAMEstillworkinembeds') %></p>
                    <textarea class="lvlTextbox codeArea" id="lvlUpEmbed" placeholder="(no embed)" savename="levelUp.message" style="width: 800px"></textarea>
                    <p class="red" id="invalidLevelUpEmbed" style="display: none"><b><%= t('dashboard.Warning') %></b><%= t('dashboard.InvalidembedJSONdataThisembedwillnotwork') %></p>
                </div>
                <div class="simpleflex">
                    <div class="sideoption">
                        <h2><%= t('dashboard.Variables') %></h2>
                        <p class="details"><%= t('dashboard.Spiceupyourmessagewithdynamicvariables') %></p>
                        <div class="varList" id="lvlUpMessageVariables">
                            <select>
                                <option disabled="" selected="" value="x"><%= t('dashboard.XP') %></option>
                                <option value="[[LEVEL]]"><%= t('dashboard.Leveleg10') %></option>
                                <option value="[[OLD_LEVEL]]"><%= t('dashboard.Previousleveleg9') %></option>
                                <option value="[[XP]]"><%= t('dashboard.XPeg10000') %></option>
                                <option value="[[NEXT_LEVEL]]"><%= t('dashboard.Nextleveleg11') %></option>
                                <option value="[[NEXT_XP]]"><%= t('dashboard.XPtonextleveleg1000') %></option>
                            </select>
                            <select>
                                <option disabled="" selected="" value="x"><%= t('dashboard.Member') %></option>
                                <option value="[[@]]"><%= t('dashboard.mentionegPolaris') %></option>
                                <option value="[[DISPLAYNAME]]"><%= t('dashboard.DisplayNameegPolaris') %></option>
                                <option value="[[USERNAME]]"><%= t('dashboard.Usernameegpolaris') %></option>
                                <option value="[[ID]]"><%= t('dashboard.IDeg98341916') %></option>
                                <option value="[[NICKNAME]]"><%= t('dashboard.Nickname') %></option>
                                <option value="[[AVATAR]]"><%= t('dashboard.AvatarURL') %></option>
                            </select>
                            <select>
                                <option disabled="" selected="" value="x"><%= t('dashboard.Server') %></option>
                                <option value="[[SERVER]]"><%= t('dashboard.Servername') %></option>
                                <option value="[[SERVER_ICON]]"><%= t('dashboard.ServericonURL') %></option>
                                <option value="[[SERVER_ID]]"><%= t('dashboard.ServerID') %></option>
                                <option value="[[CHANNEL]]"><%= t('dashboard.Channeltagegchannel') %></option>
                                <option value="[[CHANNEL_NAME]]"><%= t('dashboard.Channelnameegchannel') %></option>
                                <option value="[[CHANNEL_ID]]"><%= t('dashboard.ChannelID') %></option>
                            </select>
                            <select>
                                <option disabled="" selected="" value="x"><%= t('dashboard.Advanced') %></option>
                                <%= t('dashboard.optionvalueDISCRIMAccountDiscriminatoreg6880option') %>
                                <option value="[[LEVEL]][[NTH]]"><%= t('dashboard.Nth1st2nd3rdetc') %></option>
                                <option value="&lt;t:[[TIMESTAMP]]&gt;"><%= t('dashboard.Timestamp') %></option>
                                <option value="[[EMBEDTIMESTAMP]]"><%= t('dashboard.EmbedTimestamp') %></option>
                                <option value="[[CHOOSE | Message 1 | Message 2 | Message 3... ]]"><%= t('dashboard.Randompick') %></option>
                                <option value="[[CHOOSE | Normal message | &lt;2&gt; 2x as likely to appear | &lt;0.5&gt; 0.5x as likely to appear... ]]"><%= t('dashboard.Randompickweighted') %></option>
                                <option value="[[IFLEVEL = 10 | Only appears on level 10 (can also use &gt;, &gt;=, &lt;, &lt;=, !=, or /) ]]"><%= t('dashboard.Levelcondition') %></option>
                                <option value="[[IFROLE | Only appears upon gaining a role. You now have [[ROLE]] / [[ROLE_NAME]]! ]]"><%= t('dashboard.Rewardrolecondition') %></option>
                            </select>
                            <select id="roleVariables" style="margin-top: 7px; display: none">
                                <option disabled="" selected="" value="x"><%= t('dashboard.Role') %></option>
                                <option value="[[ROLE]]"><%= t('dashboard.RewardroleegLegendary') %></option>
                                <option value="[[ROLE_NAME]]"><%= t('dashboard.RewardrolenameegLegendary') %></option>
                            </select>
                        </div>
                    </div>
                    <div class="sideoption">
                        <h2><%= t('dashboard.Example') %></h2>
                        <p class="exampleP details" id="exampleInfo"><%= t('dashboard.Sendatestmessagetoseeifeverythingisworkingcorrectly') %></p>
                        <p class="details" id="sendingExample" style="display: none"><%= t('dashboard.Sending') %></p>
                        <p class="exampleP details" id="exampleSent" style="opacity: 100%; display: none; color: lime"><%= t('dashboard.ExamplesentCheckyourDMs') %></p>
                        <p class="exampleP details" id="exampleError" style="opacity: 100%; display: none; color: red"><%= t('dashboard.ErrorsendingexampleAreyourDMsenabled') %></p>
                        <div class="spacedflex" style="display: flex">
                            <button id="sendExample" style="background-color: var(--emojipurple)"><%= t('dashboard.SendexampleinDMs') %></button>
                            <input id="exampleLevel" max="1000" min="1" placeholder="Level" style="height: 37px; width: 90px" type="number"/>
                        </div>
                    </div>
                </div>
                <div class="simpleflex" style="margin-top: 15px">
                    <div class="sideoption">
                        <h2><%= t('dashboard.Channel') %></h2>
                        <p class="details"><%= t('dashboard.Whichchannelshouldthemessagebesentin') %></p>
                        <select id="lvlMessageSelect" savename="levelUp.channel">
                            <option value="current"><%= t('dashboard.Currentchannel') %></option>
                            <option value="dm"><%= t('dashboard.SendinDMs') %></option>
                        </select>
                    </div>
                    <div class="sideoption">
                        <h2><%= t('dashboard.Embedmode') %></h2>
                        <p class="details"><%= t('dashboard.Sendafancyembedinsteadofanormalmessageadvanced') %></p>
                        <label class="slider" style="margin-top: 5px">
                            <input db="levelUp.embed" id="toggleLvlUpEmbed" savename="db" tabindex="0" type="checkbox"/>
                            <span class="sliderspan"></span>
                        </label>
                    </div>
                </div>
            </div>
            <div class="settingBreak"></div>
            <div class="settingBox box fulllength ifmessageenabled">
                <h1><%= t('dashboard.Interval') %></h1>
                <p class=""><%= t('dashboard.Howoftenthemessageshouldbesentegevery3rdlevel') %></p>
                <div class="simpleflex" style="margin-bottom: 25px">
                    <div class="sideoption">
                        <h2><%= t('dashboard.Multiple') %></h2>
                        <p class="details"><%= t('dashboard.Levelupmessageswillonlysendwhenreachingamultipleofthisnumber') %><br/><%= t('dashboard.egamultipleof5willsendonlevels510152025') %></p>
                        <div class="field">
                            <div class="centerflex spacedflex">
                                <p><%= t('dashboard.Every') %></p>
                                <input db="levelUp.multiple" default="1" id="num_levelinterval" max="1000" min="1" savename="db" style="width: 100px" type="number"/>
                                <p><%= t('dashboard.levels') %></p>
                            </div>
                        </div>
                    </div>
