<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
    <link href="/css/polaris.css" type="text/css" rel="stylesheet">
    <link rel="icon" href="/assets/polaris.svg">
    <title><%= t('home_page.title') %></title>    
    <meta property="og:title" content="<%= t('home_page.title') %>">
    <meta property="og:description" content="<%= t('home_page.description') %>">
    <meta property="og:type" content="website">
    <meta name="theme-color" content="#00ff80">
    <meta name="twitter:card" content="summary">
</head>
<body style="height: 100%">
    <div class="middleflex" style="flex-direction: column; width: 100%; height: 100%">
        <div class="middleflex" style="margin-bottom: 40px">
            <img style="height: 160px; margin-right: 45px; user-select: none;" src="/assets/polaris.svg" alt="Logo">
            <div>
                <h1 style="color: var(--polarisgreen); font-size: 52px"><%= t('home_page.heading') %></h1>
                <p style="font-size: 26px; margin-top: 0px; line-height: 45px;"><%= t('home_page.subheading') %></p>
                <div id="buttonList" class="centerflex spacedflex" style="margin-top: 25px; height: 50px">
                    <a style="display: none" href="/invite" tabindex="-1" target="_blank" id="addLink"> 
                        <button class="fancybutton"><%= t('home_page.add_to_discord') %></button> 
                    </a>
                    <a style="display: none" href="/servers" tabindex="-1" id="manageLink"> 
                        <button class="fancybutton" id="manageButton" data-login-text="<%= t('home_page.log_in') %>">
                            <%= t('home_page.manage_servers') %>
                        </button> 
                    </a>
                </div>
            </div>
        </div>

        <div class="bottomBar">
            <div class="centerflex">
                <img src="https://gdcolon.com/assets/tails/fluff.png" style="height: 30px; margin-right: 10px" alt="Tail">
                <p style="font-size: 20px"><%= t('home_page.credits') %> <a target="_blank" class="canfocus" href="https://gdcolon.com"><span style="font-weight: 600; color: var(--colon); text-decoration: underline">Colon</span></a> :</p>
            </div>
        </div>
    </div>

    <script type="text/javascript" src="/polaris.js"></script>
    <script type="text/javascript" src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.js"></script>
    <script type="text/javascript" src="/js/home.js"></script>
</body>
</html>