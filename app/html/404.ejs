<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
    <title><%= t('dashboard.404_title') %></title>
    <meta name="theme-color" content="#00ff80">
    <link href="/css/polaris.css" type="text/css" rel="stylesheet">
    <link rel="icon" href="/assets/polaris.svg">
    
    <style>
        /* --- UTILIDADES --- */
        .mirror {
            transform: scaleX(-1);
        }
        
        /* --- LAYOUT PRINCIPAL --- */
        .main-container {
            height: 100%; 
            flex-direction: column;
        }

        .headEmpty {
            position: absolute;
            bottom: 0px;
            height: 200%;
            width: 42%;
        }

        #right {
            right: 0px;
        }
        
        /* --- ELEMENTOS INTERACTIVOS --- */
        #fumo {
           user-select: none;
           -webkit-user-select: none;
           -webkit-user-drag: none;
           -webkit-tap-highlight-color: rgba(255, 255, 255, 0); 
           -moz-user-drag: none;
           -moz-user-select: none;
           height: 250px;
        }
  
        #noThoughts {
           width: fit-content;
           margin: 60px auto; /* Reemplaza los inline margins */
           cursor: pointer;
           transform: scale(0.94);
        }
  
        /* --- ANIMACIONES --- */
        #noThoughts:hover {
           animation: brrr 0.2s infinite;
           transition-duration: 0.05s;
        }
  
        #noThoughts:active, .hell {
           animation: hyperbrrr 0.06s infinite !important;
           filter: saturate(200%) blur(1.5px) !important;
        }
  
        @keyframes brrr {
           0% { transform: translate(1px, 1px) rotate(0deg); }
           10% { transform: translate(-1px, -2px) rotate(-1deg); }
           20% { transform: translate(-3px, 0px) rotate(1deg); }
           30% { transform: translate(3px, 2px) rotate(0deg); }
           40% { transform: translate(1px, -1px) rotate(1deg); }
           50% { transform: translate(-1px, 2px) rotate(-1deg); }
           60% { transform: translate(-3px, 1px) rotate(0deg); }
           70% { transform: translate(3px, 1px) rotate(-1deg); }
           80% { transform: translate(-1px, -1px) rotate(1deg); }
           90% { transform: translate(1px, 2px) rotate(0deg); }
           100% { transform: translate(1px, -2px) rotate(-1deg); }
        }
        
        @keyframes hyperbrrr {
           0% { transform: scale(1.07) translate(6px, 3px) rotate(0deg); }
           10% { transform: scale(1.07) translate(-6px, -6px) rotate(-5deg); }
           20% { transform: scale(1.07) translate(-12px, 0px) rotate(5deg); }
           30% { transform: scale(1.07) translate(12px, 6px) rotate(0deg); }
           40% { transform: scale(1.07) translate(6px, -6px) rotate(5deg); }
           50% { transform: scale(1.07) translate(-6px, 6px) rotate(-5deg); }
           60% { transform: scale(1.07) translate(-12px, 3px) rotate(0deg); }
           70% { transform: scale(1.07) translate(12px, 3px) rotate(-5deg); }
           80% { transform: scale(1.07) translate(-6px, -6px) rotate(5deg); }
           90% { transform: scale(1.07) translate(6px, 6px) rotate(0deg); }
           100% { transform: scale(1.07) translate(6px, -6px) rotate(-5deg); }
        }
     </style>
</head>

<body>
    <div class="headEmpty" id="left"></div>
    <div class="headEmpty" id="right"></div>

    <div class="middleflex main-container">
        <h1><%= t('dashboard.404_heading') %></h1>
        
        <div id="noThoughts">
            <img id="fumo" src="/assets/nabla.svg" alt="Nabla Mascot">
        </div>
    </div>

    <script type="text/javascript" src="/polaris.js"></script>
    <script type="text/javascript" src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.js"></script>
    
    <script>
        $(document).ready(function() {
            $('#left').hover(function() { $('#fumo').removeClass("mirror"); $('#left').hide(); $('#right').show(); });
            $('#right').hover(function() { $('#fumo').addClass("mirror");   $('#left').show(); $('#right').hide(); });
            
            // Asumiendo que 'mobile' es una variable global definida en polaris.js
            if (typeof mobile !== 'undefined' && mobile) { 
                $('#fumo').click(function() { $('#fumo').toggleClass("hell"); }); 
            }
        });
    </script>
</body>
</html>